{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/((?!api/|src/|@|node_modules/|assets/|favicon\\.svg).*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/check-shows",
      "schedule": "0 9 * * *"
    }
  ]
}
